,"has_mods":false,"active":true},{"id":176,"name":"6 Xmas pies","button_name":"6 Xmas pies","price":14.9,"tab":"Catering & Misc","subcategory":"Xmas","has_mods":false,"active":true},{"id":177,"name":"Xmas Cake","button_name":"Xmas Cake","price":14.9,"tab":"Catering & Misc","subcategory":"Xmas","has_mods":false,"active":true}];

const MODS_DATA = [
  {name:"Oat Milk",price:1.00,category:"Milk"},{name:"Almond",price:1.00,category:"Milk"},
  {name:"Coconut Milk",price:1.00,category:"Milk"},{name:"Soy",price:1.00,category:"Milk"},
  {name:"Trim",price:0.00,category:"Milk"},{name:"Alt Milk",price:2.00,category:"Milk"},
  {name:"Vanilla Shot",price:0.90,category:"Extras"},{name:"Caramel Shot",price:0.90,category:"Extras"},
  {name:"Hazelnut Shot",price:0.90,category:"Extras"},{name:"Salted Caramel",price:0.90,category:"Extras"},
  {name:"X Shot",price:1.50,category:"Extras"},{name:"Single Shot",price:0.00,category:"Extras"},
  {name:"Decaf",price:1.00,category:"Extras"},{name:"Whipped Cream",price:1.00,category:"Extras"},
  {name:"Hot Milk",price:0.20,category:"Extras"},{name:"Cold Milk",price:0.20,category:"Extras"},
  {name:"X-Hot",price:0.00,category:"Preferences"},{name:"1 Sugar",price:0.00,category:"Preferences"},
  {name:"2 Sugars",price:0.00,category:"Preferences"},{name:"3 Sugars",price:0.00,category:"Preferences"},
  {name:"Equal",price:0.00,category:"Preferences"},{name:"Cinnamon",price:0.00,category:"Preferences"},
