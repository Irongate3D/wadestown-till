const TABS = ["Coffee","Food","Cold Drinks","Freezer Meals","Catering & Misc"];
const ADMIN_PIN = "1234";
const BUSINESS = { name:"Sfizio Ltd", address:"104 Wadestown Road, Wellington 6012", phone:"04-473-4916", gst:"102-355-539" };
const GST_RATE = 0.15;

let menu = [...MENU_DATA];
let activeTab = TABS[0];
let orders = [{ id: 1, name: "Tab 1", items: [] }];
let activeOrderIdx = 0;
let pendingItem = null;
let selectedMods = [];
let payMethod = '';

// --- NEW: Resizable order panel ---
function initResizable() {
  const handle = document.getElementById('resize-handle');
  const orderPanel = document.getElementById('order-panel');
  if (!handle || !orderPanel) return;
  let startX = 0, startWidth = 0;

  // Load saved width from localStorage
  const saved = localStorage.getItem('order_panel_width');
  if (saved && !isNaN(parseInt(saved))) {
    let w = Math.min(Math.max(parseInt(saved), 200), 500);
    document.documentElement.style.setProperty('--order-w', w + 'px');
  }

  function onPointerMove(e) {
    let newWidth = startWidth + (startX - e.clientX);
    newWidth = Math.min(Math.max(newWidth, 200), 500);
    document.documentElement.style.setProperty('--order-w', newWidth + 'px');
  }

  function onPointerUp() {
    const final = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--order-w'));
    localStorage.setItem('order_panel_width', final);
    window.removeEventListener('pointermove', onPointerMove);
    window.removeEventListener('pointerup', onPointerUp);
    document.body.style.userSelect = '';
  }

  function onPointerDown(e) {
    e.preventDefault();
    startX = e.clientX;
    startWidth = parseInt(getComputedStyle(orderPanel).width);
    document.body.style.userSelect = 'none';
    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerup', onPointerUp);
  }

  handle.addEventListener('pointerdown', onPointerDown);
}

// --- All existing POS functions (unchanged, except init() calls initResizable) ---
function init() { const saved = localStorage.getItem('sfizio_menu'); if (saved) { try { menu = JSON.parse(saved); } catch(e){} } renderTabs(); renderMenu(); renderOrderPanel(); initResizable(); }
function renderTabs() { const el = document.getElementById('tabs'); el.innerHTML = TABS.map(t => `<button class="tab-btn ${t===activeTab?'active':''}" onclick="switchTab('${t}')">${t}</button>`).join(''); }
function switchTab(t) { activeTab = t; renderTabs(); renderMenu(); }
function renderMenu() { const el = document.getElementById('menu-area'); const items = menu.filter(i => i.tab === activeTab && i.active); const subcats = [...new Set(items.map(i => i.subcategory))]; el.innerHTML = subcats.map(sub => { const subItems = items.filter(i => i.subcategory === sub); return `<div class="subcat-label">${sub}</div><div class="item-grid">${subItems.map(item => `<button class="item-btn ${item.has_mods?'has-mods':''}" onclick="handleItemClick(${item.id})"><span class="btn-name">${item.button_name}</span><span class="btn-price">$${item.price.toFixed(2)}</span></button>`).join('')}</div>`; }).join(''); }
function handleItemClick(id) { const item = menu.find(i => i.id === id); if (!item) return; if (item.has_mods) openModsModal(item); else addToOrder(item, []); }
function openModsModal(item) { pendingItem = item; selectedMods = []; document.getElementById('modal-item-name').textContent = item.name; document.getElementById('modal-base-price').textContent = `Base: $${item.price.toFixed(2)}`; const groups = [...new Set(MODS_DATA.map(m => m.category))]; document.getElementById('mods-scroll').innerHTML = groups.map(g => { const mods = MODS_DATA.filter(m => m.category === g); return `<div class="mod-group-label">${g}</div><div class="mods-grid">${mods.map(m => `<div class="mod-btn" id="mod-${m.name.replace(/\s/g,'_')}" onclick="toggleMod('${m.name}')"><div class="mod-name">${m.name}</div><div class="mod-price">${m.price > 0 ? '+$'+m.price.toFixed(2) : '—'}</div></div>`).join('')}</div>`; }).join(''); updateModalPrice(); document.getElementById('modal-overlay').classList.add('open'); }
function toggleMod(name) { const mod = MODS_DATA.find(m => m.name === name); const idx = selectedMods.findIndex(m => m.name === name); if (idx >= 0) { selectedMods.splice(idx, 1); document.getElementById('mod-'+name.replace(/\s/g,'_')).classList.remove('selected'); } else { selectedMods.push(mod); document.getElementById('mod-'+name.replace(/\s/g,'_')).classList.add('selected'); } updateModalPrice(); }
function updateModalPrice() { const total = pendingItem.price + selectedMods.reduce((s, m) => s + m.price, 0); document.getElementById('modal-total-price').textContent = '$' + total.toFixed(2); }
function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); pendingItem = null; selectedMods = []; }
function confirmAddItem() { if (!pendingItem) return; addToOrder(pendingItem, [...selectedMods]); closeModal(); }
function addToOrder(item, mods) { const price = item.price + mods.reduce((s,m) => s+m.price, 0); orders[activeOrderIdx].items.push({ item, mods, price, uid: Date.now()+Math.random() }); renderOrderPanel(); }
function removeFromOrder(uid) { orders[activeOrderIdx].items = orders[activeOrderIdx].items.filter(i => i.uid !== uid); renderOrderPanel(); }
function renderOrderPanel() { const tabBar = document.getElementById('tab-bar'); tabBar.innerHTML = `<button id="new-tab-btn" onclick="newOrderTab()">+</button>`; orders.forEach((o, idx) => { const btn = document.createElement('button'); btn.className = 'order-tab' + (idx === activeOrderIdx ? ' active' : ''); btn.textContent = o.name; btn.onclick = () => { activeOrderIdx = idx; renderOrderPanel(); }; tabBar.insertBefore(btn, document.getElementById('new-tab-btn')); }); const order = orders[activeOrderIdx]; const el = document.getElementById('order-items'); if (order.items.length === 0) el.innerHTML = '<div class="empty-order">No items yet</div>'; else el.innerHTML = order.items.map(i => `<div class="order-item"><div class="order-item-info"><div class="order-item-name">${i.item.button_name}</div>${i.mods.length ? `<div class="order-item-mods">${i.mods.map(m=>m.name+(m.price>0?' +$'+m.price.toFixed(2):'')).join(', ')}</div>` : ''}</div><div class="order-item-price">$${i.price.toFixed(2)}</div><button class="remove-btn" onclick="removeFromOrder(${i.uid})">✕</button></div>`).join(''); const total = order.items.reduce((s, i) => s + i.price, 0); const gst = total * GST_RATE / (1 + GST_RATE); document.getElementById('subtotal').textContent = '$' + total.toFixed(2); document.getElementById('gst-display').textContent = '$' + gst.toFixed(2); document.getElementById('total-display').textContent = '$' + total.toFixed(2); const totalItems = orders.reduce((s,o) => s+o.items.length, 0); const badge = document.getElementById('order-count'); badge.style.display = totalItems > 0 ? 'inline' : 'none'; badge.textContent = totalItems; }
function newOrderTab() { document.getElementById('name-input').value = ''; document.getElementById('name-modal').classList.add('open'); setTimeout(() => document.getElementById('name-input').focus(), 100); }
function confirmTabName() { const name = document.getElementById('name-input').value.trim() || ('Tab ' + (orders.length + 1)); orders.push({ id: Date.now(), name, items: [] }); activeOrderIdx = orders.length - 1; document.getElementById('name-modal').classList.remove('open'); renderOrderPanel(); }
document.getElementById('name-input')?.addEventListener('keydown', e => { if(e.key==='Enter') confirmTabName(); });
function voidOrder() { if (!confirm('Void this order?')) return; orders[activeOrderIdx].items = []; renderOrderPanel(); }
function openPayment(method) { const order = orders[activeOrderIdx]; const total = order.items.reduce((s,i) => s+i.price, 0); if (total === 0) return; payMethod = method; document.getElementById('pay-amount').textContent = '$' + total.toFixed(2); document.getElementById('pay-method-label').textContent = method === 'card' ? '💳 Card Payment' : '💵 Cash Payment'; document.getElementById('pay-instructions').textContent = method === 'card' ? 'Process on EFTPOS terminal, then tap Done.' : 'Collect cash, then tap Done.'; const cashCalc = document.getElementById('cash-calc'); cashCalc.style.display = method === 'cash' ? 'block' : 'none'; document.getElementById('cash-given').value = ''; document.getElementById('change-display').textContent = ''; const toggle = document.getElementById('receipt-toggle'); toggle.checked = false; updateReceiptSlider(); document.getElementById('pay-modal').classList.add('open'); }
function updateDocketSlider() { const toggle = document.getElementById('docket-toggle'); const slider = document.getElementById('docket-slider'); const knob = document.getElementById('docket-knob'); if (toggle.checked) { slider.style.background = '#0ff'; knob.style.transform = 'translateX(22px)'; } else { slider.style.background = '#3a3a4a'; knob.style.transform = 'translateX(0)'; } }
function updateReceiptSlider() { const toggle = document.getElementById('receipt-toggle'); const slider = document.getElementById('receipt-slider'); const knob = document.getElementById('receipt-knob'); if (toggle.checked) { slider.style.background = '#0ff'; knob.style.transform = 'translateX(22px)'; } else { slider.style.background = '#3a3a4a'; knob.style.transform = 'translateX(0)'; } }
function completePay() { const order = orders[activeOrderIdx]; const total = order.items.reduce((s,i) => s+i.price, 0); const wantReceipt = document.getElementById('receipt-toggle').checked; const wantDocket = document.getElementById('docket-toggle').checked; if (wantDocket) printDocket(order); if (wantReceipt) printReceipt(order, total, payMethod); }
function sendToPassPRNT(html) { const passprntUrl = 'starpassprnt://v1/print/nopreview?port=' + encodeURIComponent('TCP:192.168.1.2') + '&back=' + encodeURIComponent(window.location.href) + '&html=' + encodeURIComponent(html) + '&size=576'; window.location.href = passprntUrl; }
function printDocket(order) { const TAB_ORDER = ['Coffee','Food','Cold Drinks','Freezer Meals','Catering & Misc']; const orderNum = Date.now().toString().slice(-6); let rows = ''; TAB_ORDER.forEach(tab => { const tabItems = order.items.filter(i => i.item.tab === tab); tabItems.forEach(i => { rows += `<tr><td>${i.item.button_name}</td></tr>`; if (i.mods.length) { i.mods.filter(m=>m.name).forEach(m => { rows += `<tr><td style="padding-left:10px;font-size:11px">+ ${m.name}</td></tr>`; }); } }); }); const docketHtml = `<html><head><meta name="format-detection" content="telephone=no"><style>body{font-family:monospace;font-size:14px;width:72mm;margin:0;padding:4px;}h2{font-size:18px;text-align:center;font-weight:bold;margin:2px 0;}hr{border:none;border-top:2px solid #000;margin:4px 0;}table{width:100%;border-collapse:collapse;}td{padding:2px 3px;}</style></head><body><hr><h2>ORDER #${orderNum}</h2><hr><table>${rows}</table><hr></body></html>`; sendToPassPRNT(docketHtml); }
function printReceipt(order, total, method) { const gst = total * GST_RATE / (1 + GST_RATE); const now = new Date(); const dateStr = now.toLocaleDateString('en-NZ',{day:'2-digit',month:'short',year:'numeric'}) + ', ' + now.toLocaleTimeString('en-NZ',{hour:'2-digit',minute:'2-digit'}); const orderNum = Date.now().toString().slice(-6); let rows = ''; order.items.forEach(i => { rows += `<tr><td style="text-align:left">${i.item.button_name}</td><td style="text-align:right">$${i.price.toFixed(2)}</td></tr>`; if (i.mods.length) { i.mods.filter(m=>m.name).forEach(m => { rows += `<tr><td style="text-align:left;padding-left:12px;font-size:11px">${m.name}</td><td style="text-align:right;font-size:11px">${m.price>0?'+$'+m.price.toFixed(2):''}</td></tr>`; }); } }); const tabName = (order.name && order.name !== 'Tab 1') ? `<p>${order.name}</p>` : ''; const receiptHtml = `<html><head><meta name="format-detection" content="telephone=no"><style>body { font-family: monospace; font-size: 13px; width: 72mm; margin: 0; padding: 4px; } h2 { font-size: 14px; text-align: center; margin: 2px 0; } p { text-align: center; margin: 1px 0; font-size: 12px; } hr { border: none; border-top: 1px dashed #000; margin: 4px 0; } table { width: 100%; border-collapse: collapse; } td { padding: 1px 2px; } .total-row td { font-weight: bold; border-top: 1px dashed #000; padding-top: 3px; } .gst-row td { font-size: 11px; } .thanks { text-align: center; margin-top: 6px; font-size: 12px; }</style></head><body><h2>${BUSINESS.name}</h2><p>${BUSINESS.phone}</p><p>${BUSINESS.address}</p><p>GST ${BUSINESS.gst}</p><hr><p>${dateStr}</p><p>Order #${orderNum}</p>${tabName}<hr><table>${rows}<tr class="total-row"><td>Total</td><td style="text-align:right">$${total.toFixed(2)}</td></tr><tr class="gst-row"><td colspan="2" style="text-align:center">Includes GST of $${gst.toFixed(2)}</td></tr><tr><td>${method==='card'?'Card Payment':'Cash Payment'}</td><td style="text-align:right">$${total.toFixed(2)}</td></tr></table><hr><p class="thanks">Thank you!</p></body></html>`; sendToPassPRNT(receiptHtml); }
function openAdmin() { document.getElementById('admin-panel').classList.add('open'); document.getElementById('pin-screen').style.display = 'flex'; document.getElementById('admin-content').classList.remove('visible'); document.getElementById('pin-input').value = ''; document.getElementById('pin-error').textContent = ''; }
function closeAdmin() { document.getElementById('admin-panel').classList.remove('open'); }
function checkPin(val) { const currentPin = localStorage.getItem('admin_pin') || ADMIN_PIN; if (val.length === 4) { if (val === currentPin) { document.getElementById('pin-screen').style.display = 'none'; document.getElementById('admin-content').classList.add('visible'); renderAdminItems(); } else { document.getElementById('pin-error').textContent = 'Incorrect PIN'; document.getElementById('pin-input').value = ''; } } }
function renderAdminItems() { const el = document.getElementById('admin-items-list'); const byTab = {}; TABS.forEach(t => byTab[t] = menu.filter(i => i.tab === t)); el.innerHTML = TABS.map(t => `<div style="margin-bottom:20px"><div class="subcat-label" style="margin-bottom:8px">${t}</div>${byTab[t].map(item => `<div class="admin-item-row" id="arow-${item.id}"><input class="ai-name" value="${item.name}" onchange="updateItem(${item.id},'name',this.value)"><input class="ai-btn" value="${item.button_name}" onchange="updateItem(${item.id},'button_name',this.value)"><input class="ai-price" type="number" step="0.10" value="${item.price}" onchange="updateItem(${item.id},'price',parseFloat(this.value))"><button class="admin-del" onclick="deleteItem(${item.id})">Del</button></div>`).join('')}</div>`).join(''); }
function updateItem(id, field, val) { const item = menu.find(i => i.id === id); if (item) { item[field] = val; saveMenu(); renderMenu(); } }
function deleteItem(id) { if (!confirm('Delete this item?')) return; menu = menu.filter(i => i.id !== id); saveMenu(); renderAdminItems(); renderMenu(); }
function adminAddItem() { const name = document.getElementById('ni-name').value.trim(); const btn = document.getElementById('ni-btn').value.trim(); const price = parseFloat(document.getElementById('ni-price').value); const tab = document.getElementById('ni-tab').value; const sub = document.getElementById('ni-sub').value.trim() || tab; if (!name || !btn || isNaN(price)) { alert('Fill in all fields'); return; } const newId = Math.max(...menu.map(i=>i.id)) + 1; menu.push({ id:newId, name, button_name:btn, price, tab, subcategory:sub, has_mods: tab==='Coffee', active:true }); saveMenu(); renderAdminItems(); renderMenu(); ['ni-name','ni-btn','ni-price','ni-sub'].forEach(id => document.getElementById(id).value=''); }
function saveMenu() { localStorage.setItem('sfizio_menu', JSON.stringify(menu)); }
function changePin() { const np = document.getElementById('new-pin').value; const cp = document.getElementById('confirm-pin').value; const msg = document.getElementById('pin-change-msg'); if (np.length !== 4 || !/^\d{4}$/.test(np)) { msg.style.color='var(--red-neon)'; msg.textContent='PIN must be 4 digits'; return; } if (np !== cp) { msg.style.color='var(--red-neon)'; msg.textContent='PINs do not match'; return; } localStorage.setItem('admin_pin', np); msg.style.color='var(--neon-lime)'; msg.textContent='PIN updated ✓'; document.getElementById('new-pin').value=''; document.getElementById('confirm-pin').value=''; }
function calcChange() { const owed = orders[activeOrderIdx].items.reduce((s,i) => s+i.price, 0); const given = parseFloat(document.getElementById('cash-given').value); const el = document.getElementById('change-display'); if (isNaN(given) || given < owed) { el.textContent = given > 0 ? 'Not enough' : ''; el.style.color='var(--red-neon)'; return; } const raw = given - owed; const rounded = Math.round(raw * 10) / 10; el.style.color = 'var(--neon-lime)'; el.textContent = 'Change: $' + rounded.toFixed(2); }

init();
</script>
</body>
</html>