","has_mods":false,"active":true},{"id":150,"name":"Foxton Fizz","button_name":"Foxton Fizz","price":5.5,"tab":"Cold Drinks","subcategory":"Fridge drinks","has_mods":false,"active":true},{"id":151,"name":"Mela Juice","button_name":"Mela Juice","price":6.2,"tab":"Cold Drinks","subcategory":"Fridge drinks","has_mods":false,"active":true},{"id":152,"name":"Juice 1 Litre","button_name":"Juice 1 Litre","price":6.5,"tab":"Cold Drinks","subcategory":"Fridge drinks","has_mods":false,"active":true},{"id":153,"name":"Kids Juice","button_name":"Kids Juice","price":3.5,"tab":"Cold Drinks","subcategory":"Fridge drinks","has_mods":false,"active":true},{"id":154,"name":"Berry Smoothie","button_name":"Berry Smoothie","price":9.5,"tab":"Cold Drinks","subcategory":"Smoothies","has_mods":false,"active":true},{"id":155,"name":"Banana Smoothie","button_name":"Banana Smoothie","price":9.5,"tab":"Cold Drinks","subcategory":"Smoothies","has_mods":false,"active":true},{"id":156,"name":"Mango Smoothie","button_name":"Mango Smoothie","price":9.5,"tab":"Cold Drinks","subcategory":"Smoothies","has_mods":false,"active":true},{"id":157,"name":"Milkshake","button_name":"Milkshake","price":8.5,"tab":"Cold Drinks","subcategory":"Milkshakes","has_mods":false,"active":true},{"id":158,"name":"Iced Coffee (Black)","button_name":"Iced Coffee (Black)","price":6.9,"tab":"Cold Drinks","subcategory":"Iced Drinks","has_mods":false,"active":true},{"id":159,"name":"Iced Coffee White","button_name":"Iced Coffee (White)","price":8.5,"tab":"Cold Drinks","subcategory":"Iced Drinks","has_mods":false,"active":true},{"id":160,"name":"Iced Chocolate","button_name":"Iced Chocolate","price":8.5,"tab":"Cold Drinks","subcategory":"Iced Drinks","has_mods":false,"active":true},{"id":161,"name":"Iced Mocha","button_name":"Iced Mocha","price":9.0,"tab":"Cold Drinks","subcategory":"Iced Drinks","has_mods":false,"active":true},{"id":162,"name":"Relish","button_name":"Relish","price":10.9,"tab":"Catering & Misc","subcategory":"Mi